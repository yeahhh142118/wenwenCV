  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet" />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    /* ── Tailwind 擴充設定 ── */
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sage: '#90EE90',       /* 草綠主色 */
            'sage-dark': '#6ac96a',/* 深草綠（hover） */
            'sage-pale': '#f0fdf0',/* 極淡草綠（背景裝飾） */
          },
          fontFamily: {
            display: ['"Playfair Display"', 'serif'],
            sans: ['"Noto Sans TC"', 'sans-serif'],
          },
        }
      }
    }
  </script>

  <style>
    /* ════════════════════════════════
       全域基底
    ════════════════════════════════ */
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Sans TC', sans-serif;
      background: #ffffff;
      color: #1a1a1a;
      overflow-x: hidden;
    }

    /* ── 導航欄底線滑動效果 ── */
    .nav-link {
      position: relative;
      padding-bottom: 4px;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      left: 0; bottom: 0;
      width: 0; height: 2px;
      background: #90EE90;
      transition: width .3s ease;
    }
    .nav-link:hover::after,
    .nav-link.active::after { width: 100%; }

    /* ── 卡片懸停微升起 ── */
    .hover-lift {
      transition: transform .3s ease, box-shadow .3s ease;
    }
    .hover-lift:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0,0,0,.08);
    }

    /* ── 進度條動畫 ── */
    .skill-bar-fill {
      width: 0%;
      transition: width 1.2s cubic-bezier(.25,.46,.45,.94);
    }
    .skill-bar-fill.animated { width: var(--target-width); }

    /* ── Tab 切換 ── */
    .tab-btn {
      border-bottom: 3px solid transparent;
      transition: color .25s, border-color .25s, background .25s;
    }
    .tab-btn.active {
      color: #1a1a1a;
      border-color: #90EE90;
      font-weight: 700;
    }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* ── 裝飾圓形（背景點綴） ── */
    .deco-circle {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      opacity: .12;
    }

    /* ── Section 標題底線裝飾 ── */
    .section-title::after {
      content: '';
      display: block;
      width: 48px; height: 4px;
      background: #90EE90;
      margin-top: 10px;
      border-radius: 2px;
    }

    /* ── 時間軸 ── */
    .timeline-item { position: relative; padding-left: 24px; }
    .timeline-item::before {
      content: '';
      position: absolute;
      left: 0; top: 8px;
      width: 10px; height: 10px;
      background: #90EE90;
      border-radius: 50%;
    }
    .timeline-item::after {
      content: '';
      position: absolute;
      left: 4px; top: 18px;
      width: 2px; height: calc(100% + 8px);
      background: #e5e7eb;
    }
    .timeline-item:last-child::after { display: none; }

    /* ── 標籤（tag） ── */
    .tag {
      display: inline-block;
      background: #f0fdf0;
      color: #3a8a3a;
      border: 1px solid #c6f6c6;
      border-radius: 999px;
      padding: 2px 12px;
      font-size: .75rem;
      font-weight: 500;
    }

    /* ── Scroll-in 動畫 ── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity .7s ease, transform .7s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── 漢堡選單動畫 ── */
    #mobile-menu { max-height: 0; overflow: hidden; transition: max-height .4s ease; }
    #mobile-menu.open { max-height: 300px; }
  </style>
</head>

